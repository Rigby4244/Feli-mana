
# Example environment variables for the backend.
# Copy this file to `.env` and fill real values for local testing.
# DO NOT commit `.env` — use your host/Render secret manager for production.

PORT=5000

# MongoDB connection string (required)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/mernapp?retryWrites=true&w=majority

# JWT secret used to sign/verify tokens (required)
JWT_SECRET=replace_with_a_secure_random_value

# Admin account used by `seedadmin.js` (optional)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisAdminPassword

# Email account for nodemailer (only required if you send emails)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password-or-app-password

# Frontend origin for CORS — optional when no frontend exists
# Set to your frontend URL (e.g. http://localhost:3000) or leave blank to allow all origins
FRONTEND_ORIGIN=

# When deployed behind a reverse proxy (Render sets this for you)
TRUST_PROXY=true

# Environment mode
NODE_ENV=production

# Notes:
# - On Render: set these values in the Service → Environment → Environment Secrets.
# - Never commit real credentials. Rotate any secrets accidentally committed.

